<!--
  local_rules_ssh.xml
  Regla de correlacion: Fuerza bruta SSH.
  Se dispara cuando se detectan 10 o mas fallos de autenticacion SSH (rule id 5716,
  regla nativa de Wazuh para "sshd: Failed password") desde la MISMA IP de origen
  en una ventana de 60 segundos.
-->
<group name="local,ssh,">

  <rule id="100001" level="10" frequency="10" timeframe="60">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip />
    <description>Ataque de fuerza bruta SSH desde $(srcip)</description>
    <group>authentication_failures,brute_force,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

</group>
